Name: or-pattern
=-=
app [main!] { pf: platform "https://github.com/roc-lang/basic-cli/releases/download/0.20.0/X73hGh05nNTkDHU06FHC0YfFaQB1pimX7gncRcao5mU.tar.br" }

f : Something -> Something
f = |z| match List.get(nfa, state_ind) {
	Ok(A(b, c)) => Ok(A(c, b))
	Ok(_)
	| Ok(_)
	| Err(_) => Ok(32)
}
